# Local Netlify folder
.netlify

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Secrets — never commit
.env
.env.*
*.token
*.pem
nf-token.txt

# Claude Code local state. The allowlist file captures literal bash commands,
# which can include bearer tokens / API keys passed to curl. Keep it local.
.claude/

# Logs / build artifacts
*.log
last_deploy.log
dist/
.cache/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Office lock files (appear while a .docx/.xlsx is open)
~$*
~*.tmp

# Unpacked docx working directories (used by the docx skill, never deployed)
*_unpacked/
*_unpacked*/
docx_unpacked_*/

# Internal drafts — earlier asset iterations kept off the deploy
_drafts/

# Oversized assets — exceed GitHub's 100 MB limit; not used by the live site.
# If any of these become site-linked, host them on Netlify Large Media or external storage.
assets/MPSA BOOKS/HANDBOOKS/*.pdf
assets/drive-download-*.zip
*.zip

